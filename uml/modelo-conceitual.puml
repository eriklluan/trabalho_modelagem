@startuml
hide circle
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam nodesep 60
skinparam ranksep 80
skinparam class {
  BackgroundColor #FFFFFF
  BorderColor #2563EB
  ArrowColor #42526E
  FontSize 13
  AttributeFontSize 12
}

title Modelo Conceitual do Dominio - Plataforma Classroom Online

class Usuario {
  id
  nome
  email
  perfil
  status
}

class Estudante
class Professor
class Coordenador
class Administrador

class Turma {
  codigo
  nome
  periodo
  status
}

class ParticipacaoTurma {
  papelNaTurma
  dataEntrada
  status
}

class Atividade {
  titulo
  descricao
  dataPublicacao
  prazoEntrega
  valor
  status
}

class Entrega {
  dataEnvio
  status
  comentarioAluno
  --
  + calcularStatus(prazoAtividade) : Status
}

class Arquivo {
  nome
  tipo
  tamanho
  url
}

class Avaliacao {
  nota
  feedback
  dataCorrecao
  liberada
  --
  + validarNota() : Boolean
}

class Aviso {
  titulo
  mensagem
  dataPublicacao
}

class Comentario {
  texto
  dataCriacao
}

class Notificacao {
  canal
  mensagem
  dataEnvio
  status
}

class IndicadorPedagogico {
  tipo
  valor
  periodo
}

class SugestaoApoio {
  descricao
  prioridade
  justificativa
}

Usuario <|-- Estudante
Usuario <|-- Professor
Usuario <|-- Coordenador
Usuario <|-- Administrador

Turma "1" -- "0..*" ParticipacaoTurma
Usuario "1" -- "0..*" ParticipacaoTurma
Professor "1" -- "0..*" Turma : responsavel >

Turma "1" -- "0..*" Atividade
Atividade "1" -- "0..*" Entrega
Estudante "1" -- "0..*" Entrega
Entrega "1" -- "0..1" Avaliacao
Atividade "0..*" -- "0..*" Arquivo : anexos
Entrega "0..*" -- "0..*" Arquivo : arquivos enviados

Turma "1" -- "0..*" Aviso
Usuario "1" -- "0..*" Comentario
Atividade "0..1" -- "0..*" Comentario
Aviso "0..1" -- "0..*" Comentario

Usuario "1" -- "0..*" Notificacao
Turma "1" -- "0..*" IndicadorPedagogico
IndicadorPedagogico "1" -- "0..*" SugestaoApoio
SugestaoApoio "0..*" --> Estudante : pode recomendar apoio para

note right of Atividade
Regra de negocio:
toda atividade pertence a uma turma
e possui prazo de entrega.
end note

note bottom of Avaliacao
Nota e feedback so devem ficar
visiveis quando liberados.
end note

note right of Entrega
RN02: Status calculado comparando
dataEnvio com prazoEntrega da Atividade.
Metodo calcularStatus() implementa essa logica.
end note

note right of Avaliacao
Observacao: nota deve ser representada com precisao de ate 2 casas decimais (ex.: decimal(4,2)).
Isso facilita alinhamento com a constraint no banco (CHECK) e a validacao em Avaliacao.validarNota().
end note
@enduml