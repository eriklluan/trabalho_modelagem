<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_Classroom_Activity_Corrigido"
  targetNamespace="https://classroom-online.example/bpmn">
  
  <bpmn:process id="Process_Publicacao_Atividade" name="Publicacao e correcao de atividade" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Principal">
      <bpmn:lane id="Lane_Professor" name="Professor">
        <bpmn:flowNodeRef>StartEvent_Inicio</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CriarAtividade</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_PublicarAtividade</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SubProcess_CorrecaoEntregas</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_ProcessoConcluido</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Sistema" name="Sistema">
        <bpmn:flowNodeRef>Task_ValidarPermissao</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Autorizado</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_SemPermissao</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_NotificarEstudantes</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RegistrarEntrega</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Estudante" name="Estudante">
        <bpmn:flowNodeRef>Task_AcessarAtividade</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_EnviarResposta</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <!-- FLUXO PRINCIPAL: PUBLICACAO -->
    <bpmn:startEvent id="StartEvent_Inicio" name="Necessidade de criar atividade">
      <bpmn:outgoing>Flow_01</bpmn:outgoing>
    </bpmn:startEvent>
    
    <bpmn:userTask id="Task_CriarAtividade" name="Criar atividade com descrição, prazo e turma">
      <bpmn:incoming>Flow_01</bpmn:incoming>
      <bpmn:outgoing>Flow_02</bpmn:outgoing>
    </bpmn:userTask>
    
    <bpmn:serviceTask id="Task_ValidarPermissao" name="Validar se professor está vinculado à turma (RN01)">
      <bpmn:incoming>Flow_02</bpmn:incoming>
      <bpmn:outgoing>Flow_03</bpmn:outgoing>
    </bpmn:serviceTask>
    
    <bpmn:exclusiveGateway id="Gateway_Autorizado" name="Professor autorizado?">
      <bpmn:incoming>Flow_03</bpmn:incoming>
      <bpmn:outgoing>Flow_04_Sim</bpmn:outgoing>
      <bpmn:outgoing>Flow_04_Nao</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    
    <bpmn:endEvent id="EndEvent_SemPermissao" name="Publicação negada">
      <bpmn:incoming>Flow_04_Nao</bpmn:incoming>
      <bpmn:terminateEventDefinition />
    </bpmn:endEvent>
    
    <bpmn:userTask id="Task_PublicarAtividade" name="Confirmar publicação da atividade">
      <bpmn:incoming>Flow_04_Sim</bpmn:incoming>
      <bpmn:outgoing>Flow_05</bpmn:outgoing>
    </bpmn:userTask>
    
    <bpmn:serviceTask id="Task_NotificarEstudantes" name="Notificar estudantes sobre nova atividade">
      <bpmn:documentation>Se o envio de notificacoes falhar, o sistema deve registrar o erro de auditoria, enfileirar a tentativa de retry e nao impedir a publicacao da atividade. Falhas persistentes devem gerar alerta operacional.</bpmn:documentation>
      <bpmn:incoming>Flow_05</bpmn:incoming>
      <bpmn:outgoing>Flow_06</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- FLUXO ESTUDANTE: ENTREGA (Pode acontecer N vezes) -->
    <bpmn:userTask id="Task_AcessarAtividade" name="Acessar atividade publicada">
      <bpmn:incoming>Flow_06</bpmn:incoming>
      <bpmn:outgoing>Flow_07</bpmn:outgoing>
    </bpmn:userTask>
    
    <bpmn:userTask id="Task_EnviarResposta" name="Enviar resposta da atividade">
      <bpmn:incoming>Flow_07</bpmn:incoming>
      <bpmn:outgoing>Flow_08</bpmn:outgoing>
    </bpmn:userTask>
    
    <bpmn:serviceTask id="Task_RegistrarEntrega" name="Registrar entrega com status (NO_PRAZO ou ATRASADA) - RN02">
      <bpmn:documentation>Sistema compara timestamp da entrega com prazo da atividade e marca status automaticamente</bpmn:documentation>
      <bpmn:incoming>Flow_08</bpmn:incoming>
      <bpmn:outgoing>Flow_09</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- SUBPROCESSO: CORRECAO (Multi-instância - uma para cada entrega) -->
    <bpmn:subProcess id="SubProcess_CorrecaoEntregas" name="Corrigir entregas dos estudantes (N vezes)">
      <bpmn:incoming>Flow_09</bpmn:incoming>
      <bpmn:outgoing>Flow_16</bpmn:outgoing>
      
      <bpmn:multiInstanceLoopCharacteristics isSequential="false" />
      
      <!-- Início do subprocesso -->
      <bpmn:startEvent id="SubStart_Correcao" name="Entrega registrada">
        <bpmn:outgoing>SubFlow_01</bpmn:outgoing>
      </bpmn:startEvent>
      
      <bpmn:userTask id="SubTask_Corrigir" name="Corrigir atividade">
        <bpmn:incoming>SubFlow_01</bpmn:incoming>
        <bpmn:outgoing>SubFlow_02</bpmn:outgoing>
      </bpmn:userTask>
      
      <bpmn:userTask id="SubTask_RegistrarNota" name="Registrar nota (0-10) e feedback (RN06)">
        <bpmn:incoming>SubFlow_02</bpmn:incoming>
        <bpmn:outgoing>SubFlow_03</bpmn:outgoing>
      </bpmn:userTask>
      
      <bpmn:exclusiveGateway id="SubGateway_ValidarNota" name="Nota entre 0 e 10?">
        <bpmn:incoming>SubFlow_03</bpmn:incoming>
        <bpmn:outgoing>SubFlow_04_Sim</bpmn:outgoing>
        <bpmn:outgoing>SubFlow_04_Nao</bpmn:outgoing>
      </bpmn:exclusiveGateway>
      
      <bpmn:serviceTask id="SubTask_NotificarErro" name="Notificar erro de validação">
        <bpmn:incoming>SubFlow_04_Nao</bpmn:incoming>
        <bpmn:outgoing>SubFlow_05</bpmn:outgoing>
      </bpmn:serviceTask>
      
      <bpmn:serviceTask id="SubTask_LiberarResultado" name="Liberar resultado ao estudante">
        <bpmn:incoming>SubFlow_04_Sim</bpmn:incoming>
        <bpmn:outgoing>SubFlow_06</bpmn:outgoing>
      </bpmn:serviceTask>
      
      <bpmn:endEvent id="SubEnd_Corrigido" name="Correção concluída">
        <bpmn:incoming>SubFlow_06</bpmn:incoming>
      </bpmn:endEvent>
      
      <!-- Fluxos internos do subprocesso -->
      <bpmn:sequenceFlow id="SubFlow_01" sourceRef="SubStart_Correcao" targetRef="SubTask_Corrigir" />
      <bpmn:sequenceFlow id="SubFlow_02" sourceRef="SubTask_Corrigir" targetRef="SubTask_RegistrarNota" />
      <bpmn:sequenceFlow id="SubFlow_03" sourceRef="SubTask_RegistrarNota" targetRef="SubGateway_ValidarNota" />
      <bpmn:sequenceFlow id="SubFlow_04_Sim" name="Sim" sourceRef="SubGateway_ValidarNota" targetRef="SubTask_LiberarResultado" />
      <bpmn:sequenceFlow id="SubFlow_04_Nao" name="Não" sourceRef="SubGateway_ValidarNota" targetRef="SubTask_NotificarErro" />
      <bpmn:sequenceFlow id="SubFlow_05" sourceRef="SubTask_NotificarErro" targetRef="SubTask_RegistrarNota" />
      <bpmn:sequenceFlow id="SubFlow_06" sourceRef="SubTask_LiberarResultado" targetRef="SubEnd_Corrigido" />
    </bpmn:subProcess>

    <bpmn:endEvent id="EndEvent_ProcessoConcluido" name="Processo concluído">
      <bpmn:incoming>Flow_16</bpmn:incoming>
    </bpmn:endEvent>

    <!-- SEQUENCE FLOWS -->
    <bpmn:sequenceFlow id="Flow_01" sourceRef="StartEvent_Inicio" targetRef="Task_CriarAtividade" />
    <bpmn:sequenceFlow id="Flow_02" sourceRef="Task_CriarAtividade" targetRef="Task_ValidarPermissao" />
    <bpmn:sequenceFlow id="Flow_03" sourceRef="Task_ValidarPermissao" targetRef="Gateway_Autorizado" />
    <bpmn:sequenceFlow id="Flow_04_Sim" name="Sim" sourceRef="Gateway_Autorizado" targetRef="Task_PublicarAtividade" />
    <bpmn:sequenceFlow id="Flow_04_Nao" name="Não" sourceRef="Gateway_Autorizado" targetRef="EndEvent_SemPermissao" />
    <bpmn:sequenceFlow id="Flow_05" sourceRef="Task_PublicarAtividade" targetRef="Task_NotificarEstudantes" />
    <bpmn:sequenceFlow id="Flow_06" sourceRef="Task_NotificarEstudantes" targetRef="Task_AcessarAtividade" />
    <bpmn:sequenceFlow id="Flow_07" sourceRef="Task_AcessarAtividade" targetRef="Task_EnviarResposta" />
    <bpmn:sequenceFlow id="Flow_08" sourceRef="Task_EnviarResposta" targetRef="Task_RegistrarEntrega" />
    <bpmn:sequenceFlow id="Flow_09" sourceRef="Task_RegistrarEntrega" targetRef="SubProcess_CorrecaoEntregas" />
    <bpmn:sequenceFlow id="Flow_16" sourceRef="SubProcess_CorrecaoEntregas" targetRef="EndEvent_ProcessoConcluido" />
  </bpmn:process>
  
</bpmn:definitions>